{
  "manifest_version": 3,
  "name": "Psi Ψ - Smart Tabs Privacy Agent",
  "version": "1.0",
  "description": "Localized AI Orchestration and Zero-Data Leakage Environment Management Suite.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}